# GAMEBOT Environment Configuration
# Copy to .env and set your production values

# ===== DATABASE =====
DATABASE_URL=sqlite:///gamebot.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/gamebot

# ===== SECURITY =====
SECRET_KEY=your-secret-key-change-this-in-production
JWT_SECRET=jwt-secret-key-change-this-in-production
ACCOUNT_ENCRYPTION_KEY=change-this-too-or-account-data-cannot-be-decrypted-after-rotation

# ===== REDIS (Caching) =====
REDIS_HOST=localhost
REDIS_PORT=6379

# ===== API =====
PORT=5000
DEBUG=False

# ===== STRIPE (Payments) =====
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_PUBLIC_KEY=pk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ===== SENTRY (Error Tracking) =====
SENTRY_DSN=https://your-sentry-url

# ===== EMAIL (Notifications) =====
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# ===== CDN (Static Files) =====
CDN_URL=https://your-cdn-url.com

# ===== ANALYTICS =====
GOOGLE_ANALYTICS_ID=G-your-analytics-id

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,https://gamebot.com

# ===== WORKER QUEUE =====
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_FILE=/var/log/gamebot/app.log
